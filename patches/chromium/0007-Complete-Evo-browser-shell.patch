+class ClaudePanelView : public views::View {
+  METADATA_HEADER(ClaudePanelView, views::View)
+
+ public:
+  explicit ClaudePanelView(base::RepeatingClosure close) {
+    SetLayoutManager(std::make_unique<views::BoxLayout>(
+        views::BoxLayout::Orientation::kVertical, gfx::Insets(20), 14));
+    SetBackground(views::CreateSolidBackground(ui::kColorSysSurface));
+    SetBorder(views::CreateSolidSidedBorder(gfx::Insets::TLBR(0, 1, 0, 0),
+                                            ui::kColorSysDivider));
+
+    auto* header = AddChildView(std::make_unique<views::View>());
+    auto* header_layout =
+        header->SetLayoutManager(std::make_unique<views::BoxLayout>(
+            views::BoxLayout::Orientation::kHorizontal));
+    header_layout->set_cross_axis_alignment(views::LayoutAlignment::kCenter);
+    auto* title =
+        header->AddChildView(std::make_unique<views::Label>(u"✦  Claude"));
+    title->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    header_layout->SetFlexForView(title, 1);
+    auto* close_button = header->AddChildView(
+        std::make_unique<views::LabelButton>(std::move(close), u"×"));
+    close_button->SetTooltipText(u"Close Claude sidebar");
+
+    auto* badge =
+        AddChildView(std::make_unique<views::Label>(u"INTEGRATION STUB"));
+    badge->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    badge->SetEnabledColor(ui::kColorLabelForegroundSecondary);
+
+    auto* message = AddChildView(std::make_unique<views::Label>(
+        u"Claude chat will live here with the current page, selected text, "
+        u"tabs, and MCP tools available as context."));
+    message->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    message->SetMultiLine(true);
+    message->SetAllowCharacterBreak(true);
+
+    auto* context = AddChildView(
+        std::make_unique<views::Label>(u"Page context\nReady for integration"));
+    context->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    context->SetMultiLine(true);
+    context->SetBackground(
+        views::CreateRoundedRectBackground(ui::kColorSysNeutralContainer, 10));
+
+    auto* composer = AddChildView(std::make_unique<views::Textfield>());
+    composer->SetPlaceholderText(u"Ask Claude about this page…");
+    composer->SetEnabled(false);
+    composer->SetAccessibleName(u"Claude composer placeholder");
+    SetVisible(false);
+  }
+};
