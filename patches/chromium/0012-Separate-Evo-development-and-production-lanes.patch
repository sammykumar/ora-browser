diff --git a/evo/install-production.sh b/evo/install-production.sh
new file mode 100755
index 0000000000000000000000000000000000000000..b6c71b35f6999730b27cf9389050486831471719
--- /dev/null
+++ b/evo/install-production.sh
@@ -0,0 +1,25 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+evo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+src_dir="$(cd "${evo_dir}/.." && pwd)"
+out_dir="${EVO_OUT_DIR:-${src_dir}/out/Evo}"
+source_app="${out_dir}/Evo.app"
+install_app="${EVO_INSTALL_PATH:-/Applications/Evo.app}"
+
+"${evo_dir}/build.sh"
+
+if pgrep -f "${install_app}/Contents/MacOS/Evo" >/dev/null 2>&1; then
+    echo "Quit the production Evo app before installing a new build." >&2
+    exit 1
+fi
+
+ditto "${source_app}" "${install_app}"
+production_frameworks="${install_app}/Contents/Frameworks"
+while IFS= read -r -d '' library; do
+    ditto "${library}" "${production_frameworks}/$(basename "${library}")"
+done < <(find "${out_dir}" -maxdepth 1 -type f -name '*.dylib' -print0)
+
+"${evo_dir}/sign.sh" "${install_app}"
+echo "Production app installed at ${install_app}"
