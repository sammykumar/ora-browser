       Profile::FromWebUI(web_ui), chrome::kChromeUIEvoAIHost);
   webui::SetupWebUIDataSource(source, kEvoAiResources, IDR_EVO_AI_EVO_AI_HTML);
+  web_ui->AddMessageHandler(std::make_unique<EvoAIMessageHandler>());
 }
