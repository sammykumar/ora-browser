diff --git a/chrome/browser/ui/webui/evo_ai/evo_ai_ui.cc b/chrome/browser/ui/webui/evo_ai/evo_ai_ui.cc
index 51ec43223407b3e94bf2fdb0b64d75764ae70d7f..7f9f1e0b576813fca76e0cb9b9dc00417b0f9c27 100644
--- a/chrome/browser/ui/webui/evo_ai/evo_ai_ui.cc
+++ b/chrome/browser/ui/webui/evo_ai/evo_ai_ui.cc
@@ -2,15 +2,198 @@
 
 #include "chrome/browser/ui/webui/evo_ai/evo_ai_ui.h"
 
+#include <array>
+#include <string>
+#include <utility>
+
+#include "base/base_paths.h"
+#include "base/command_line.h"
+#include "base/files/file_path.h"
