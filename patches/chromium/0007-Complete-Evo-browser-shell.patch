+class CommandBarView : public views::View, public views::TextfieldController {
+  METADATA_HEADER(CommandBarView, views::View)
+
+ public:
+  CommandBarView(base::RepeatingCallback<void(const std::u16string&)> submit,
+                 base::RepeatingClosure dismiss)
+      : submit_(std::move(submit)), dismiss_(std::move(dismiss)) {
+    SetLayoutManager(std::make_unique<views::BoxLayout>(
+        views::BoxLayout::Orientation::kVertical, gfx::Insets(16), 8));
+    SetBackground(views::CreateRoundedRectBackground(ui::kColorSysSurface, 16));
+    SetBorder(views::CreateSolidBorder(1, ui::kColorSysDivider));
+    SetPaintToLayer();
+    layer()->SetFillsBoundsOpaquely(false);
+
+    auto* title =
+        AddChildView(std::make_unique<views::Label>(u"EVO COMMAND BAR"));
+    title->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    title->SetEnabledColor(ui::kColorLabelForegroundSecondary);
+
+    textfield_ = AddChildView(std::make_unique<views::Textfield>());
+    textfield_->SetController(this);
+    textfield_->SetPlaceholderText(u"Search, enter a URL, or type Claude");
+    textfield_->SetAccessibleName(u"Evo command bar");
+    textfield_->SetBorder(nullptr);
+    textfield_->SetBackgroundColor(ui::kColorSysSurface);
+    textfield_->SetPreferredSize(gfx::Size(kEvoCommandBarWidth - 32, 40));
+
+    auto* hint = AddChildView(std::make_unique<views::Label>(
+        u"Return to open  ·  Esc to close  ·  Claude opens the AI sidebar"));
+    hint->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    hint->SetEnabledColor(ui::kColorLabelForegroundSecondary);
+    SetVisible(false);
+  }
+
+  void Show(const std::u16string& initial_text) {
+    textfield_->SetText(initial_text);
+    SetVisible(true);
+    textfield_->RequestFocus();
+    textfield_->SelectAll(false);
+  }
+
+  void Hide() {
+    SetVisible(false);
+    textfield_->SetText(std::u16string());
+  }
+
+  bool HandleKeyEvent(views::Textfield* sender,
+                      const ui::KeyEvent& event) override {
+    if (event.type() != ui::EventType::kKeyPressed) {
+      return false;
+    }
+    if (event.key_code() == ui::VKEY_ESCAPE) {
+      dismiss_.Run();
+      return true;
+    }
+    if (event.key_code() == ui::VKEY_RETURN && !sender->GetText().empty()) {
+      submit_.Run(std::u16string(sender->GetText()));
+      return true;
+    }
+    return false;
+  }
+
+ private:
+  raw_ptr<views::Textfield> textfield_ = nullptr;
+  base::RepeatingCallback<void(const std::u16string&)> submit_;
+  base::RepeatingClosure dismiss_;
+};
