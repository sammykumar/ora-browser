diff --git a/chrome/browser/resources/evo_ai/evo_ai.css b/chrome/browser/resources/evo_ai/evo_ai.css
new file mode 100644
index 0000000000000000000000000000000000000000..1421bf4a76121462c47cdb8f3f21d51ebfe57638
--- /dev/null
+++ b/chrome/browser/resources/evo_ai/evo_ai.css
@@ -0,0 +1,147 @@
+:root {
+  color-scheme: light dark;
+  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+  --surface: color-mix(in srgb, Canvas 92%, #7759ff 8%);
+  --surface-strong: color-mix(in srgb, Canvas 82%, #7759ff 18%);
+  --border: color-mix(in srgb, CanvasText 14%, transparent);
+  --muted: color-mix(in srgb, CanvasText 62%, transparent);
+  --accent: #7759ff;
+}
+
+* { box-sizing: border-box; }
+
+body {
+  margin: 0;
+  background: Canvas;
+  color: CanvasText;
+}
+
+main {
+  width: min(820px, calc(100% - 40px));
+  margin: 0 auto;
+  padding: 48px 0 72px;
+}
+
+header {
+  display: flex;
+  align-items: center;
+  gap: 18px;
+  margin-bottom: 30px;
+}
+
+.mark {
+  display: grid;
+  place-items: center;
+  width: 54px;
+  height: 54px;
+  border-radius: 16px;
+  color: white;
+  background: linear-gradient(145deg, #9c7cff, #5135d9);
+  font-size: 27px;
+  font-weight: 700;
+  box-shadow: 0 12px 28px color-mix(in srgb, var(--accent) 34%, transparent);
+}
+
+h1,
+ h2,
+ p { margin: 0; }
+
+h1 { font-size: 30px;
+ letter-spacing: -0.04em; }
+
+h2 { font-size: 15px; }
+
+.eyebrow { color: var(--accent);
+ font-size: 12px;
+ font-weight: 750;
+ letter-spacing: .16em; }
+
+.subtitle { margin-top: 5px;
+ color: var(--muted); }
+
+section {
+  margin-top: 16px;
+  padding: 20px;
+  border: 1px solid var(--border);
+  border-radius: 18px;
+  background: var(--surface);
+}
+
+.section-heading,
+.composer-footer,
+.connection {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+}
+
+.pill {
+  padding: 5px 9px;
+  border-radius: 999px;
+  background: var(--surface-strong);
+  color: var(--accent);
+  font-size: 11px;
+  font-weight: 650;
+}
+
+.pill.pending { color: var(--muted); }
+
+.page-title { margin-top: 18px;
+ font-size: 17px;
+ font-weight: 650; }
+
+.page-url { margin-top: 5px;
+ color: var(--muted);
+ font-size: 13px;
+ overflow-wrap: anywhere; }
+
+.suggestions { display: flex;
+ flex-wrap: wrap;
+ gap: 8px;
+ margin: 18px 0 12px; }
+
+button {
+  border: 1px solid var(--border);
+  border-radius: 10px;
+  padding: 8px 12px;
+  background: Canvas;
+  color: CanvasText;
+  font: inherit;
+  cursor: pointer;
+}
+
+button:hover:not(:disabled) { border-color: var(--accent); }
+
+button:disabled { cursor: default;
+ opacity: .48; }
+
+button.primary { background: var(--accent);
+ color: white;
+ border-color: transparent; }
+
+textarea {
+  width: 100%;
+  resize: vertical;
+  border: 1px solid var(--border);
+  border-radius: 12px;
+  padding: 13px;
+  background: Canvas;
+  color: CanvasText;
+  font: inherit;
+}
+
+.composer-footer { margin-top: 10px; }
+
+.composer-footer p,
+.connection p,
+.architecture-note { color: var(--muted);
+ font-size: 12px; }
+
+.connection { margin-top: 18px; }
+
+.connection p { margin-top: 4px; }
+
+.architecture-note { margin-top: 18px;
+ padding-top: 14px;
+ border-top: 1px solid var(--border); }
