+// TODO(evo): Replace this bridge with the provider/MCP Mojo service.
+// eslint-disable-next-line no-restricted-imports
+import {sendWithPromise} from 'chrome://resources/js/cr.js';
+
+interface ProviderStatus {
+  available: boolean;
+  provider: string;
+}
+
+interface PromptResponse {
+  success: boolean;
+  output?: string;
+  error?: string;
+}
+
 const params = new URLSearchParams(window.location.search);
 const pageTitle = params.get('title');
 const pageUrl = params.get('url');
+const prompt = document.querySelector<HTMLTextAreaElement>('#prompt');
+const run = document.querySelector<HTMLButtonElement>('#run');
+const composerStatus = document.querySelector<HTMLElement>('#composer-status');
+const providerStatus = document.querySelector<HTMLElement>('#provider-status');
+const conversation = document.querySelector<HTMLElement>('#conversation');
+let providerAvailable = false;
 
 if (pageUrl) {
   const contextStatus = document.querySelector<HTMLElement>('#context-status');
@@ -16,11 +37,90 @@ if (pageUrl) {
 for (const button of
      document.querySelectorAll<HTMLButtonElement>('[data-prompt]')) {
   button.addEventListener('click', () => {
-    const prompt = document.querySelector<HTMLTextAreaElement>('#prompt');
-    const status = document.querySelector<HTMLElement>('#composer-status');
-    if (prompt && status) {
+    if (prompt && composerStatus) {
       prompt.value = button.dataset['prompt'] || '';
-      status.textContent = 'Prompt ready. Configure a provider to run it.';
+      composerStatus.textContent = 'Prompt ready.';
+      prompt.focus();
     }
   });
 }
+
+function appendMessage(kind: 'user'|'assistant'|'error', text: string) {
+  if (!conversation) {
+    return;
+  }
+  const message = document.createElement('div');
+  message.className = `message ${kind}`;
+  message.textContent = text;
+  conversation.appendChild(message);
+  message.scrollIntoView({behavior: 'smooth', block: 'nearest'});
+}
+
+async function refreshProviderStatus() {
+  const status = await sendWithPromise<ProviderStatus>(
+      'getEvoAIProviderStatus');
+  providerAvailable = status.available;
+  if (providerStatus) {
+    providerStatus.textContent = status.available ?
+        `${status.provider} ready` : `${status.provider} not found`;
+    providerStatus.classList.toggle('pending', !status.available);
+  }
+  if (prompt) {
+    prompt.disabled = !status.available;
+  }
+  if (run) {
+    run.disabled = !status.available;
+  }
+  if (composerStatus) {
+    composerStatus.textContent = status.available ?
+        'Local provider ready. Tools are disabled for browser prompts.' :
+        'Install Claude Code to enable AI responses.';
+  }
+}
+
+async function submitPrompt() {
+  const text = prompt?.value.trim();
+  if (!text || !providerAvailable || !run || !prompt || !composerStatus) {
+    return;
+  }
+
+  appendMessage('user', text);
+  prompt.value = '';
+  prompt.disabled = true;
+  run.disabled = true;
+  run.textContent = 'Running…';
+  composerStatus.textContent = 'Claude is thinking locally…';
+
+  try {
+    const response = await sendWithPromise<PromptResponse>('runEvoAIPrompt', {
+      prompt: text,
+      pageTitle: pageTitle || '',
+      pageUrl: pageUrl || '',
+    });
+    if (response.success && response.output) {
+      appendMessage('assistant', response.output);
+      composerStatus.textContent = 'Response complete.';
+    } else {
+      appendMessage('error', response.error || 'Claude could not respond.');
+      composerStatus.textContent = 'Request failed.';
+    }
+  } catch {
+    appendMessage('error', 'Evo lost contact with the local AI provider.');
+    composerStatus.textContent = 'Request failed.';
+  } finally {
+    prompt.disabled = false;
+    run.disabled = false;
+    run.textContent = 'Run';
+    prompt.focus();
+  }
+}
+
+run?.addEventListener('click', submitPrompt);
+prompt?.addEventListener('keydown', event => {
+  if (event.key === 'Enter' && (event.metaKey || event.ctrlKey)) {
+    event.preventDefault();
+    submitPrompt();
+  }
+});
+
+refreshProviderStatus();
