diff --git a/chrome/browser/evo_runtime/evo_runtime_manager.cc b/chrome/browser/evo_runtime/evo_runtime_manager.cc
new file mode 100644
index 0000000000000000000000000000000000000000..3e531fb2d06249fabf3f3cf617bdd74e696a765e
--- /dev/null
+++ b/chrome/browser/evo_runtime/evo_runtime_manager.cc
@@ -0,0 +1,213 @@
+// Copyright 2026 SK Productions LLC
+
+#include "chrome/browser/evo_runtime/evo_runtime_manager.h"
+
+#include <utility>
+
+#include "base/base_paths.h"
+#include "base/environment.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/path_service.h"
+#include "base/process/launch.h"
+#include "base/rand_util.h"
+#include "base/strings/strcat.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/task/thread_pool.h"
+#include "base/threading/platform_thread.h"
+#include "base/time/time.h"
+#include "base/values.h"
+#include "chrome/common/chrome_paths.h"
+
+namespace evo {
+
+namespace {
+
+constexpr base::TimeDelta kRuntimeStartupTimeout = base::Seconds(15);
+constexpr base::TimeDelta kRuntimePollInterval = base::Milliseconds(50);
+
+base::FilePath ResolveRuntimeBinary() {
+  std::unique_ptr<base::Environment> environment = base::Environment::Create();
+  std::optional<std::string> override = environment->GetVar("EVO_RUNTIME_PATH");
+  if (override && !override->empty()) {
+    return base::FilePath::FromUTF8Unsafe(*override);
+  }
+
+  base::FilePath executable;
+  if (!base::PathService::Get(base::FILE_EXE, &executable)) {
+    return base::FilePath();
+  }
+  return executable.DirName()
+      .DirName()
+      .Append(FILE_PATH_LITERAL("Resources"))
+      .Append(FILE_PATH_LITERAL("evo-runtime"));
+}
+
+base::FilePath ResolveReadyFile() {
+  base::FilePath user_data;
+  if (!base::PathService::Get(chrome::DIR_USER_DATA, &user_data)) {
+    return base::FilePath();
+  }
+  return user_data.Append(FILE_PATH_LITERAL("Evo Runtime"))
+      .Append(FILE_PATH_LITERAL("ready.json"));
+}
+
+}  // namespace
+
+struct EvoRuntimeManager::LaunchResult {
+  base::Process process;
+  base::FilePath ready_file;
+  GURL base_url;
+  std::string error;
+};
+
+EvoRuntimeManager& EvoRuntimeManager::Get() {
+  static base::NoDestructor<EvoRuntimeManager> instance;
+  return *instance;
+}
+
+EvoRuntimeManager::EvoRuntimeManager() = default;
+
+EvoRuntimeManager::~EvoRuntimeManager() = default;
+
+void EvoRuntimeManager::Start() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  if (state_ == RuntimeState::kStarting || state_ == RuntimeState::kReady) {
+    return;
+  }
+
+  state_ = RuntimeState::kStarting;
+  error_.clear();
+  base_url_ = GURL();
+  bearer_token_ = base::HexEncode(base::RandBytesAsString(32));
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE,
+      {base::MayBlock(), base::TaskPriority::USER_VISIBLE,
+       base::TaskShutdownBehavior::CONTINUE_ON_SHUTDOWN},
+      base::BindOnce(&EvoRuntimeManager::LaunchOnBlockingThread, bearer_token_),
+      base::BindOnce(&EvoRuntimeManager::OnLaunchComplete,
+                     weak_ptr_factory_.GetWeakPtr()));
+}
+
+void EvoRuntimeManager::Stop() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  weak_ptr_factory_.InvalidateWeakPtrs();
+  if (process_.IsValid()) {
+    process_.Terminate(0, false);
+    process_.Close();
+  }
+  state_ = RuntimeState::kStopped;
+  base_url_ = GURL();
+  bearer_token_.clear();
+  error_.clear();
+  ready_file_.clear();
+}
+
+void EvoRuntimeManager::EnsureRunning() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  int exit_code = 0;
+  const bool process_exited =
+      process_.IsValid() &&
+      process_.WaitForExitWithTimeout(base::TimeDelta(), &exit_code);
+  if (state_ == RuntimeState::kStarting ||
+      (state_ == RuntimeState::kReady && process_.IsValid() &&
+       !process_exited)) {
+    return;
+  }
+  Stop();
+  Start();
+}
+
+RuntimeSnapshot EvoRuntimeManager::GetSnapshot() const {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  return {.state = state_, .base_url = base_url_, .error = error_};
+}
+
+GURL EvoRuntimeManager::GetEndpoint(std::string_view path) const {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  if (state_ != RuntimeState::kReady || !base_url_.is_valid()) {
+    return GURL();
+  }
+  return base_url_.Resolve(path);
+}
+
+const std::string& EvoRuntimeManager::bearer_token() const {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  return bearer_token_;
+}
+
+EvoRuntimeManager::LaunchResult EvoRuntimeManager::LaunchOnBlockingThread(
+    std::string token) {
+  LaunchResult result;
+  const base::FilePath binary = ResolveRuntimeBinary();
+  if (binary.empty() || !base::PathExists(binary)) {
+    result.error = base::StrCat(
+        {"Bundled Evo Runtime was not found at ", binary.AsUTF8Unsafe()});
+    return result;
+  }
+
+  result.ready_file = ResolveReadyFile();
+  if (result.ready_file.empty() ||
+      !base::CreateDirectory(result.ready_file.DirName())) {
+    result.error = "Could not create the Evo Runtime state directory";
+    return result;
+  }
+  base::DeleteFile(result.ready_file);
+
+  base::LaunchOptions options;
+  options.environment["EVO_RUNTIME_TOKEN"] = std::move(token);
+  options.environment["EVO_RUNTIME_PORT"] = "0";
+  options.environment["EVO_RUNTIME_READY_FILE"] =
+      result.ready_file.AsUTF8Unsafe();
+  result.process = base::LaunchProcess(base::CommandLine(binary), options);
+  if (!result.process.IsValid()) {
+    result.error = "Failed to launch the bundled Evo Runtime";
+    return result;
+  }
+
+  const base::TimeTicks deadline =
+      base::TimeTicks::Now() + kRuntimeStartupTimeout;
+  while (base::TimeTicks::Now() < deadline) {
+    std::string contents;
+    if (base::ReadFileToString(result.ready_file, &contents)) {
+      std::optional<base::DictValue> ready =
+          base::JSONReader::ReadDict(contents, base::JSON_PARSE_RFC);
+      std::optional<int> port = ready ? ready->FindInt("port") : std::nullopt;
+      if (port && *port > 0 && *port <= 65535) {
+        result.base_url = GURL(base::StrCat(
+            {"http://127.0.0.1:", base::NumberToString(*port), "/"}));
+        return result;
+      }
+    }
+
+    int exit_code = 0;
+    if (result.process.WaitForExitWithTimeout(base::TimeDelta(), &exit_code)) {
+      result.error =
+          base::StrCat({"Evo Runtime exited during startup with code ",
+                        base::NumberToString(exit_code)});
+      return result;
+    }
+    base::PlatformThread::Sleep(kRuntimePollInterval);
+  }
+
+  result.process.Terminate(1, false);
+  result.error = "Timed out waiting for Evo Runtime to become ready";
+  return result;
+}
+
+void EvoRuntimeManager::OnLaunchComplete(LaunchResult result) {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(sequence_checker_);
+  if (!result.error.empty()) {
+    state_ = RuntimeState::kError;
+    error_ = std::move(result.error);
+    process_ = std::move(result.process);
+    return;
+  }
+  process_ = std::move(result.process);
+  ready_file_ = std::move(result.ready_file);
+  base_url_ = std::move(result.base_url);
+  state_ = RuntimeState::kReady;
+}
+
+}  // namespace evo
