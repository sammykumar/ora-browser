@@ -0,0 +1,17 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+evo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+src_dir="$(cd "${evo_dir}/.." && pwd)"
+dev_out_dir="${EVO_DEV_OUT_DIR:-${src_dir}/out/EvoDev}"
+dev_app="${dev_out_dir}/Evo Dev.app"
+dev_profile_dir="${EVO_DEV_PROFILE_DIR:-${HOME}/Library/Application Support/Evo Chromium Dev}"
+
+"${evo_dir}/build-dev.sh"
+
+open -n "${dev_app}" --args \
+    "--user-data-dir=${dev_profile_dir}" \
+    --use-mock-keychain \
+    --no-first-run \
+    "$@"
