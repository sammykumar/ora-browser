@@ -0,0 +1,71 @@
+// Copyright 2026 SK Productions LLC
+
+#ifndef CHROME_BROWSER_EVO_RUNTIME_EVO_RUNTIME_MANAGER_H_
+#define CHROME_BROWSER_EVO_RUNTIME_EVO_RUNTIME_MANAGER_H_
+
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/memory/weak_ptr.h"
+#include "base/no_destructor.h"
+#include "base/process/process.h"
+#include "base/sequence_checker.h"
+#include "url/gurl.h"
+
+namespace evo {
+
+enum class RuntimeState {
+  kStopped,
+  kStarting,
+  kReady,
+  kError,
+};
+
+struct RuntimeSnapshot {
+  RuntimeState state = RuntimeState::kStopped;
+  GURL base_url;
+  std::string error;
+};
+
+// Browser-process owner for the signed Evo Runtime sidecar. Runtime credentials
+// never leave this object and are therefore unavailable to renderer processes.
+class EvoRuntimeManager {
+ public:
+  static EvoRuntimeManager& Get();
+
+  EvoRuntimeManager(const EvoRuntimeManager&) = delete;
+  EvoRuntimeManager& operator=(const EvoRuntimeManager&) = delete;
+
+  void Start();
+  void Stop();
+  void EnsureRunning();
+
+  RuntimeSnapshot GetSnapshot() const;
+  GURL GetEndpoint(std::string_view path) const;
+  const std::string& bearer_token() const;
+
+ private:
+  friend class base::NoDestructor<EvoRuntimeManager>;
+
+  struct LaunchResult;
+
+  EvoRuntimeManager();
+  ~EvoRuntimeManager();
+
+  static LaunchResult LaunchOnBlockingThread(std::string token);
+  void OnLaunchComplete(LaunchResult result);
+
+  RuntimeState state_ = RuntimeState::kStopped;
+  GURL base_url_;
+  std::string bearer_token_;
+  std::string error_;
+  base::FilePath ready_file_;
+  base::Process process_;
+
+  SEQUENCE_CHECKER(sequence_checker_);
+  base::WeakPtrFactory<EvoRuntimeManager> weak_ptr_factory_{this};
+};
+
+}  // namespace evo
+
+#endif  // CHROME_BROWSER_EVO_RUNTIME_EVO_RUNTIME_MANAGER_H_
