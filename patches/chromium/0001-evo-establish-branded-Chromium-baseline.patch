diff --git a/evo/README.md b/evo/README.md
new file mode 100644
index 0000000000000000000000000000000000000000..0f075148d1958d995ec3f12fe5a0cef281bf5641
--- /dev/null
+++ b/evo/README.md
@@ -0,0 +1,25 @@
+# Evo Chromium development
+
+This directory holds the small, Evo-specific layer over Chromium.
+
+## Build
+
+```bash
+./evo/build.sh
+```
+
+The first build compiles Chromium. Later builds are incremental and normally
+compile only the affected targets before relinking the application.
+
+## Run
+
+```bash
+./evo/run.sh
+```
+
+The macOS application is generated at `out/Evo/Evo.app`. Its browser data is
+kept separately in `~/Library/Application Support/Evo Chromium` so it does not
+collide with the earlier Swift/CEF Evo experiments.
+
+Set `DEPOT_TOOLS_DIR`, `DEVELOPER_DIR`, or `EVO_OUT_DIR` to override the local
+defaults used by the scripts.
diff --git a/evo/args.gn b/evo/args.gn
new file mode 100644
index 0000000000000000000000000000000000000000..e80ff1d2c570037b6a691ee1f7633c67adbd4e4e
--- /dev/null
+++ b/evo/args.gn
@@ -0,0 +1,7 @@
+is_debug = false
+is_component_build = true
+symbol_level = 0
+blink_symbol_level = 0
+v8_symbol_level = 0
+target_cpu = "arm64"
+use_lld = false
diff --git a/evo/build.sh b/evo/build.sh
new file mode 100755
index 0000000000000000000000000000000000000000..2b37b183156793debfa0416c57f4272be140907e
--- /dev/null
+++ b/evo/build.sh
@@ -0,0 +1,27 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+evo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+src_dir="$(cd "${evo_dir}/.." && pwd)"
+out_dir="${EVO_OUT_DIR:-${src_dir}/out/Evo}"
+depot_tools_dir="${DEPOT_TOOLS_DIR:-${src_dir}/../../depot_tools}"
+
+if [[ ! -x "${depot_tools_dir}/autoninja" ]]; then
+    echo "depot_tools was not found at ${depot_tools_dir}." >&2
+    echo "Set DEPOT_TOOLS_DIR to its absolute path and try again." >&2
+    exit 1
+fi
+
+export DEVELOPER_DIR="${DEVELOPER_DIR:-/Applications/Xcode.app/Contents/Developer}"
+export PATH="${depot_tools_dir}:/usr/bin:/bin:/usr/sbin:/sbin"
+export RUST_LOG="${RUST_LOG:-error}"
+export NINJA_SUMMARIZE_BUILD="${NINJA_SUMMARIZE_BUILD:-1}"
+
+mkdir -p "${out_dir}"
