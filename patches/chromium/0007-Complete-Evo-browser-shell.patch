+void BrowserView::ShowEvoCommandBar(bool include_current_url) {
+  std::u16string initial_text;
+  if (include_current_url) {
+    if (WebContents* contents =
+            browser_->tab_strip_model()->GetActiveWebContents()) {
+      const GURL& url = contents->GetLastCommittedURL();
+      if (url.is_valid() && !url.SchemeIs("chrome") && !url.SchemeIs("about")) {
+        initial_text = base::UTF8ToUTF16(url.spec());
+      }
+    }
+  }
+  evo_command_bar_->Show(initial_text);
+  InvalidateLayout();
+}
+
+void BrowserView::HideEvoCommandBar() {
+  evo_command_bar_->Hide();
+  if (WebContents* contents =
+          browser_->tab_strip_model()->GetActiveWebContents()) {
+    contents->Focus();
+  }
+}
+
+void BrowserView::SubmitEvoCommand(const std::u16string& command) {
+  const std::u16string normalized = base::ToLowerASCII(command);
+  if (normalized == u"claude" || normalized == u"> claude") {
+    HideEvoCommandBar();
+    ToggleEvoClaudePanel();
+    return;
+  }
+
+  HideEvoCommandBar();
+  OmniboxEditModel* model =
+      GetLocationBarView()->GetOmniboxController()->edit_model();
+  if (model->CanPasteAndGo(command)) {
+    model->PasteAndGo(command, base::TimeTicks::Now());
+  }
+}
+
+void BrowserView::ToggleEvoClaudePanel() {
+  evo_claude_panel_->SetVisible(!evo_claude_panel_->GetVisible());
+  InvalidateLayout();
+}
+
+void BrowserView::OpenEvoAI() {
+  chrome::AddTabAt(browser_.get(), GURL("chrome://evo-ai"), -1, true);
+}
