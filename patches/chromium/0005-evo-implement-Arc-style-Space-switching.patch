+void VerticalTabStripBottomContainer::CreateSpace() {
+  if (!tab_strip_model_) {
+    return;
+  }
+
+  browser_->OpenGURL(GURL(chrome::kChromeUINewTabURL),
+                     WindowOpenDisposition::NEW_FOREGROUND_TAB);
+  const int active_index = tab_strip_model_->active_index();
+  if (active_index == TabStripModel::kNoTab) {
+    return;
+  }
+
+  const tab_groups::TabGroupId group =
+      tab_strip_model_->AddToNewGroup({active_index});
+  TabGroup* tab_group = tab_strip_model_->group_model()->GetTabGroup(group);
+  tab_groups::TabGroupVisualData visual_data = *tab_group->visual_data();
+  visual_data.SetTitle(
+      u"Space " + base::NumberToString16(
+                      tab_strip_model_->group_model()->ListTabGroups().size()));
+  tab_strip_model_->ChangeTabGroupVisuals(group, std::move(visual_data), true);
+  tab_strip_model_->SetFocusedGroup(group);
+  ScheduleSpaceButtonsRebuild();
+}
+
+void VerticalTabStripBottomContainer::EnsureSpaces() {
+  if (!tab_strip_model_ || !tab_strip_model_->group_model()) {
+    return;
+  }
+
+  int space_number = 1;
+  for (const tab_groups::TabGroupId& group_id :
+       tab_strip_model_->group_model()->ListTabGroups()) {
+    TabGroup* group = tab_strip_model_->group_model()->GetTabGroup(group_id);
+    if (group->visual_data()->title().empty()) {
+      tab_groups::TabGroupVisualData visual_data = *group->visual_data();
+      visual_data.SetTitle(u"Space " + base::NumberToString16(space_number));
+      tab_strip_model_->ChangeTabGroupVisuals(group_id, std::move(visual_data),
+                                              true);
+    }
+    ++space_number;
+  }
+
+  std::vector<int> ungrouped_tabs;
+  for (int index = 0; index < tab_strip_model_->count(); ++index) {
+    tabs::TabInterface* tab = tab_strip_model_->GetTabAtIndex(index);
+    if (!tab->IsPinned() && !tab->GetGroup().has_value()) {
+      ungrouped_tabs.push_back(index);
+    }
+  }
+
+  std::optional<tab_groups::TabGroupId> space_to_focus;
+  if (!ungrouped_tabs.empty()) {
+    const tab_groups::TabGroupId group =
+        tab_strip_model_->AddToNewGroup(ungrouped_tabs);
+    TabGroup* tab_group = tab_strip_model_->group_model()->GetTabGroup(group);
+    tab_groups::TabGroupVisualData visual_data = *tab_group->visual_data();
+    visual_data.SetTitle(
+        u"Space " +
+        base::NumberToString16(
+            tab_strip_model_->group_model()->ListTabGroups().size()));
+    tab_strip_model_->ChangeTabGroupVisuals(group, std::move(visual_data),
+                                            true);
+    space_to_focus = group;
+  } else if (!tab_strip_model_->GetFocusedGroup().has_value()) {
+    tabs::TabInterface* active_tab = tab_strip_model_->GetActiveTab();
+    if (active_tab && active_tab->GetGroup().has_value()) {
+      space_to_focus = active_tab->GetGroup();
+    } else {
+      const std::vector<tab_groups::TabGroupId> groups =
+          tab_strip_model_->group_model()->ListTabGroups();
+      if (!groups.empty()) {
+        space_to_focus = groups.front();
+      }
+    }
+  }
+
+  if (space_to_focus.has_value()) {
+    tab_strip_model_->SetFocusedGroup(space_to_focus);
+  }
+  ScheduleSpaceButtonsRebuild();
+}
+
+void VerticalTabStripBottomContainer::SelectSpace(
+    std::optional<tab_groups::TabGroupId> group) {
+  if (!tab_strip_model_) {
+    return;
+  }
+  tab_strip_model_->SetFocusedGroup(group);
+  UpdateSpaceButtonSelection();
+}
+
+void VerticalTabStripBottomContainer::CycleSpace(int direction) {
+  if (!tab_strip_model_ || direction == 0) {
+    return;
+  }
+
+  const std::vector<tab_groups::TabGroupId> groups =
+      tab_strip_model_->group_model()->ListTabGroups();
+  if (groups.empty()) {
+    return;
+  }
+
+  const std::optional<tab_groups::TabGroupId> focused =
+      tab_strip_model_->GetFocusedGroup();
+  int current = 0;
+  if (focused.has_value()) {
+    const auto it = std::ranges::find(groups, focused.value());
+    if (it != groups.end()) {
+      current = static_cast<int>(std::distance(groups.begin(), it));
+    }
+  }
+
+  const int count = static_cast<int>(groups.size());
+  const int next = (current + (direction > 0 ? 1 : -1) + count) % count;
+  SelectSpace(groups[static_cast<size_t>(next)]);
+}
+
+void VerticalTabStripBottomContainer::RebuildSpaceButtons() {
+  space_buttons_rebuild_scheduled_ = false;
+  if (!tab_strip_model_ || !space_buttons_) {
+    return;
+  }
+
+  space_buttons_->RemoveAllChildViews();
+  group_space_buttons_.clear();
+
+  for (const tab_groups::TabGroupId& group :
+       tab_strip_model_->group_model()->ListTabGroups()) {
+    TabGroup* tab_group = tab_strip_model_->group_model()->GetTabGroup(group);
+    std::u16string title = tab_group->visual_data()->title();
+    if (title.empty()) {
+      title = u"Space";
+    }
+
+    auto button = std::make_unique<views::LabelButton>(
+        base::BindRepeating(&VerticalTabStripBottomContainer::SelectSpace,
+                            base::Unretained(this), std::make_optional(group)),
+        u"•");
+    button->SetTooltipText(title);
+    button->SetMinSize(gfx::Size(28, 28));
+    views::LabelButton* button_ptr =
+        space_buttons_->AddChildView(std::move(button));
+    group_space_buttons_.emplace_back(group, button_ptr);
+  }
+
+  auto add_button = std::make_unique<views::LabelButton>(
+      base::BindRepeating(&VerticalTabStripBottomContainer::CreateSpace,
+                          base::Unretained(this)),
+      u"+");
+  add_button->SetTooltipText(u"Create Space");
+  add_button->SetMinSize(gfx::Size(28, 28));
+  space_buttons_->AddChildView(std::move(add_button));
+
+  UpdateSpaceButtonSelection();
+  InvalidateLayout();
+}
+
+void VerticalTabStripBottomContainer::ScheduleSpaceButtonsRebuild() {
+  if (space_buttons_rebuild_scheduled_) {
+    return;
+  }
+  space_buttons_rebuild_scheduled_ = true;
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&VerticalTabStripBottomContainer::RebuildSpaceButtons,
+                     weak_factory_.GetWeakPtr()));
+}
+
+void VerticalTabStripBottomContainer::UpdateSpaceButtonSelection() {
+  if (!tab_strip_model_) {
+    return;
+  }
+
+  const std::optional<tab_groups::TabGroupId> focused =
+      tab_strip_model_->GetFocusedGroup();
+  for (const auto& [group, button] : group_space_buttons_) {
+    button->SetText(focused == group ? u"●" : u"•");
+  }
+}
+
+void VerticalTabStripBottomContainer::OnTabGroupChanged(
+    const TabGroupChange& change) {
+  ScheduleSpaceButtonsRebuild();
+}
+
+void VerticalTabStripBottomContainer::OnTabGroupAdded(
+    const tab_groups::TabGroupId& group_id) {
+  ScheduleSpaceButtonsRebuild();
+}
+
+void VerticalTabStripBottomContainer::OnTabGroupWillBeRemoved(
+    const tab_groups::TabGroupId& group_id) {
