+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Evo AI</title>
+    <link rel="stylesheet" href="evo_ai.css">
+  </head>
+  <body>
+    <main>
+      <header>
+        <div class="mark">E</div>
+        <div>
+          <p class="eyebrow">EVO</p>
+          <h1>AI workspace</h1>
+          <p class="subtitle">Page-aware assistance with a local MCP boundary.</p>
+        </div>
+      </header>
+
+      <section class="context-card">
+        <div class="section-heading">
+          <h2>Page context</h2>
+          <span id="context-status" class="pill">No page attached</span>
+        </div>
+        <p id="page-title" class="page-title">Open this page from a tab’s context menu.</p>
+        <p id="page-url" class="page-url"></p>
+      </section>
+
+      <section>
+        <div class="section-heading">
+          <h2>Ask Evo</h2>
+          <span class="pill pending">Provider not configured</span>
+        </div>
+        <div class="suggestions">
+          <button data-prompt="Summarize this page and identify the key decisions.">Summarize</button>
+          <button data-prompt="Explain this page and highlight anything surprising.">Explain</button>
+          <button data-prompt="Extract the actionable next steps from this page.">Next steps</button>
+        </div>
+        <textarea id="prompt" rows="5" placeholder="Ask about the attached page…"></textarea>
+        <div class="composer-footer">
+          <p id="composer-status">The provider adapter will connect here.</p>
+          <button id="run" class="primary" disabled>Run</button>
+        </div>
+      </section>
+
+      <section>
+        <div class="section-heading">
+          <h2>MCP connections</h2>
+          <span class="pill pending">Bridge offline</span>
+        </div>
+        <div class="connection">
+          <div>
+            <strong>Local project tools</strong>
+            <p>stdio and Streamable HTTP servers will appear here.</p>
+          </div>
+          <button disabled>Connect server</button>
+        </div>
+        <p class="architecture-note">
+          UI contract established. The next implementation connects this page
+          to Evo’s provider abstraction and a local MCP client service.
+        </p>
+      </section>
+    </main>
+    <script type="module" src="evo_ai.js"></script>
+  </body>
+</html>
diff --git a/chrome/browser/resources/evo_ai/evo_ai.ts b/chrome/browser/resources/evo_ai/evo_ai.ts
new file mode 100644
index 0000000000000000000000000000000000000000..019a9277839b64941d3b4b023314d73d48516103
--- /dev/null
+++ b/chrome/browser/resources/evo_ai/evo_ai.ts
@@ -0,0 +1,26 @@
+const params = new URLSearchParams(window.location.search);
+const pageTitle = params.get('title');
+const pageUrl = params.get('url');
+
+if (pageUrl) {
+  const contextStatus = document.querySelector<HTMLElement>('#context-status');
+  const title = document.querySelector<HTMLElement>('#page-title');
+  const url = document.querySelector<HTMLElement>('#page-url');
+  if (contextStatus && title && url) {
+    contextStatus.textContent = 'Page attached';
+    title.textContent = pageTitle || 'Untitled page';
+    url.textContent = pageUrl;
+  }
+}
+
+for (const button of
+     document.querySelectorAll<HTMLButtonElement>('[data-prompt]')) {
+  button.addEventListener('click', () => {
+    const prompt = document.querySelector<HTMLTextAreaElement>('#prompt');
+    const status = document.querySelector<HTMLElement>('#composer-status');
+    if (prompt && status) {
+      prompt.value = button.dataset['prompt'] || '';
+      status.textContent = 'Prompt ready. Configure a provider to run it.';
+    }
+  });
+}
