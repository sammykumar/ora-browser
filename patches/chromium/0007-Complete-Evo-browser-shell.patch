+        views::BoxLayout::Orientation::kVertical, gfx::Insets::VH(12, 5), 10));
+    layout->set_cross_axis_alignment(views::LayoutAlignment::kCenter);
+    SetBackground(views::CreateSolidBackground(ui::kColorSysSurface));
+    SetBorder(views::CreateSolidSidedBorder(gfx::Insets::TLBR(0, 1, 0, 0),
+                                            ui::kColorSysDivider));
+
+    auto* claude = AddChildView(
+        std::make_unique<views::LabelButton>(std::move(toggle_claude), u"✦"));
+    claude->SetTooltipText(u"Claude chat");
+    claude->SetAccessibleName(u"Toggle Claude chat sidebar");
+
+    auto* evo_ai = AddChildView(
+        std::make_unique<views::LabelButton>(std::move(open_evo_ai), u"◈"));
+    evo_ai->SetTooltipText(u"Open Evo AI and MCP workspace");
+    evo_ai->SetAccessibleName(u"Open Evo AI");
+
+    auto* page_context = AddChildView(std::make_unique<views::LabelButton>(
+        views::Button::PressedCallback(), u"⌘"));
+    page_context->SetTooltipText(u"Page context (coming next)");
+    page_context->SetEnabled(false);
+  }
+};
