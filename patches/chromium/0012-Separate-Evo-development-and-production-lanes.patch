diff --git a/evo/README.md b/evo/README.md
index 6d6446ad312806d95f7a159eaa5b9cc4a0f484cd..281e38abadaf6c2ae03fb9001d8189a8dab0cd61 100644
--- a/evo/README.md
+++ b/evo/README.md
@@ -2,27 +2,67 @@
 
 This directory holds the small, Evo-specific layer over Chromium.
 
-## Build
+## Development and production lanes
+
+Evo deliberately uses separate development and production applications and
+profiles:
+
+| Lane | Application | Profile | Who tests it |
+|---|---|---|---|
+| Development | `out/EvoDev/Evo Dev.app` | `~/Library/Application Support/Evo Chromium Dev` | Codex/automated testing |
+| Production | `/Applications/Evo.app` | `~/Library/Application Support/Evo Chromium` | Sam/daily dogfooding |
+
+The development launcher also passes `--use-mock-keychain`, so automated tests
+cannot read or modify production cookies, passwords, extensions, or keychain
+material. Its runtime mappings live in
+`~/Library/Application Support/Evo Runtime Dev`, and its Sidekick workspace is
+`~/.evo/sidekick-dev`; production continues to use Evo Runtime's normal global
+state and `~/.evo/sidekick`. Codex must test the development lane and must not
+launch or reset the production profile. Sam performs final acceptance testing
+in production.
+
+Both applications are signed with the stable Apple Development identity
+`Apple Development: Munusamy Kumar (VXL54TYT5T)`. Set
+`EVO_CODESIGN_IDENTITY` only when intentionally using another valid identity.
+
+## Build and test development
 
 ```bash
-./evo/build.sh
+./evo/run-dev.sh
+# ./evo/run.sh is an alias for the same isolated lane.
 ```
 
+This incrementally builds Chromium, creates the separately branded development
+application, signs it, and launches it with the development profile.
+
+## Promote to production
+
+```bash
+./evo/install-production.sh
+```
+
+This installs the signed build at `/Applications/Evo.app` without touching the
+production profile. The installer packages the component-build libraries into
+the application so the production copy is self-contained. Evo must be closed
+while it is replaced. Sam then launches and tests the production application
+normally.
+
 The first build compiles Chromium. Later builds are incremental and normally
-compile only the affected targets before relinking the application.
+compile only affected targets before relinking the application.
 
 ## Run
 
 ```bash
-./evo/run.sh
+open /Applications/Evo.app
 ```
 
-The macOS application is generated at `out/Evo/Evo.app`. Its browser data is
-kept separately in `~/Library/Application Support/Evo Chromium` so it does not
-collide with the earlier Swift/CEF Evo experiments.
+The production browser data remains in
+`~/Library/Application Support/Evo Chromium`, preserving extensions,
+preferences, cookies, spaces, and other dogfooding state across upgrades.
 
-Set `DEPOT_TOOLS_DIR`, `DEVELOPER_DIR`, or `EVO_OUT_DIR` to override the local
-defaults used by the scripts.
+Set `DEPOT_TOOLS_DIR`, `DEVELOPER_DIR`, `EVO_OUT_DIR`, `EVO_DEV_OUT_DIR`,
+`EVO_DEV_PROFILE_DIR`, `EVO_DEV_RUNTIME_STATE_DIR`,
+`EVO_DEV_SIDEKICK_WORKSPACE`, or `EVO_INSTALL_PATH` to override local defaults.
 
 ## Planning
 
diff --git a/evo/build-dev.sh b/evo/build-dev.sh
new file mode 100755
index 0000000000000000000000000000000000000000..b51c6b2809ed19545300c096c404ecd5e14a057b
--- /dev/null
+++ b/evo/build-dev.sh
@@ -0,0 +1,37 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+evo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+src_dir="$(cd "${evo_dir}/.." && pwd)"
+production_out_dir="${EVO_OUT_DIR:-${src_dir}/out/Evo}"
+dev_out_dir="${EVO_DEV_OUT_DIR:-${src_dir}/out/EvoDev}"
+production_app="${production_out_dir}/Evo.app"
+dev_app="${dev_out_dir}/Evo Dev.app"
+dev_runtime_state_dir="${EVO_DEV_RUNTIME_STATE_DIR:-${HOME}/Library/Application Support/Evo Runtime Dev}"
+dev_sidekick_workspace="${EVO_DEV_SIDEKICK_WORKSPACE:-${HOME}/.evo/sidekick-dev}"
+
+"${evo_dir}/build.sh"
+
+mkdir -p "${dev_out_dir}"
+ditto "${production_app}" "${dev_app}"
+while IFS= read -r -d '' library; do
+    ln -sfn "${library}" "${dev_out_dir}/$(basename "${library}")"
+done < <(find "${production_out_dir}" -maxdepth 1 -type f -name '*.dylib' -print0)
+/usr/libexec/PlistBuddy -c "Set :CFBundleDisplayName Evo Dev" \
+    "${dev_app}/Contents/Info.plist"
+/usr/libexec/PlistBuddy -c "Set :CFBundleName Evo Dev" \
+    "${dev_app}/Contents/Info.plist"
+/usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier com.skproductions.evo.dev" \
+    "${dev_app}/Contents/Info.plist"
+/usr/libexec/PlistBuddy -c "Set :CrProductDirName Evo Chromium Dev" \
+    "${dev_app}/Contents/Info.plist"
+/usr/libexec/PlistBuddy -c \
+    "Add :LSEnvironment:EVO_RUNTIME_STATE_DIR string ${dev_runtime_state_dir}" \
+    "${dev_app}/Contents/Info.plist"
+/usr/libexec/PlistBuddy -c \
+    "Add :LSEnvironment:EVO_SIDEKICK_WORKSPACE string ${dev_sidekick_workspace}" \
+    "${dev_app}/Contents/Info.plist"
+
+"${evo_dir}/sign.sh" "${dev_app}"
+echo "Development app: ${dev_app}"
