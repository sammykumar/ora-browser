+void VerticalTabStripRegionView::OnScrollEvent(ui::ScrollEvent* event) {
+  if (event->handled()) {
+    return;
+  }
+  const float horizontal = event->x_offset();
+  const float vertical = event->y_offset();
+  if (std::abs(horizontal) > std::abs(vertical) * 1.25f) {
+    evo_space_swipe_offset_ += horizontal;
+    if (std::abs(evo_space_swipe_offset_) >= 80.0f) {
+      bottom_button_container_->CycleSpace(evo_space_swipe_offset_ > 0 ? 1
+                                                                       : -1);
+      evo_space_swipe_offset_ = 0.0f;
+    }
+    event->SetHandled();
+    return;
+  }
+
+  if (std::abs(vertical) > std::abs(horizontal)) {
+    evo_space_swipe_offset_ = 0.0f;
+  }
+  TabStripRegionView::OnScrollEvent(event);
+}
