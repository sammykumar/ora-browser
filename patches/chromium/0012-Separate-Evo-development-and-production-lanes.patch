diff --git a/evo/sign.sh b/evo/sign.sh
new file mode 100755
index 0000000000000000000000000000000000000000..180d55091c45707c5845b3ba5abc1c22dd9b8c94
--- /dev/null
+++ b/evo/sign.sh
@@ -0,0 +1,29 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+
+if [[ $# -ne 1 ]]; then
+    echo "Usage: $0 /absolute/path/to/Evo.app" >&2
+    exit 2
+fi
+
+app_path="$1"
+signing_identity="${EVO_CODESIGN_IDENTITY:-Apple Development: Munusamy Kumar (VXL54TYT5T)}"
+runtime_path="${app_path}/Contents/Resources/evo-runtime"
+
+if [[ ! -d "${app_path}" ]] || [[ ! -x "${runtime_path}" ]]; then
+    echo "Evo app or bundled runtime was not found at ${app_path}." >&2
+    exit 1
+fi
+
+if ! security find-identity -v -p codesigning | grep -Fq "\"${signing_identity}\""; then
+    echo "The requested signing identity is not available: ${signing_identity}" >&2
+    echo "Set EVO_CODESIGN_IDENTITY to a valid Apple Development identity." >&2
+    exit 1
+fi
+
+codesign --force --sign "${signing_identity}" --timestamp=none \
+    "${runtime_path}" >/dev/null
+codesign --force --deep --sign "${signing_identity}" --timestamp=none \
+    --preserve-metadata=entitlements,flags,runtime "${app_path}" >/dev/null
+codesign --verify --deep --strict "${app_path}"
